@inherits SessionChild
<PBFrontend.UI.Formatting.Box.Presets.Shadow.ShadowPageBox>
    <Header>
        <PBFrontend.UI.Formatting.PBTitle>
            <PBFrontend.UI.Miscellaneous.Loading.LoadingFrame @ref="refreshLoadingFrameRef">
                <PBFrontend.UI.Formatting.Localize Value="Orders" />&nbsp;<PBFrontend.UI.Miscellaneous.Loading.Children.NotLoading><span class="text-primary clickable oi oi-reload" @onclick="async ()=>await refreshLoadingFrameRef.Load(async ()=>{await Refresh();Task.Delay(1500).Wait();})"></span></PBFrontend.UI.Miscellaneous.Loading.Children.NotLoading><PBFrontend.UI.Miscellaneous.Loading.Children.Loading><PBFrontend.UI.Miscellaneous.Loading.Spinner></PBFrontend.UI.Miscellaneous.Loading.Spinner></PBFrontend.UI.Miscellaneous.Loading.Children.Loading>
            </PBFrontend.UI.Miscellaneous.Loading.LoadingFrame>
        </PBFrontend.UI.Formatting.PBTitle>
    </Header>
    <ChildContent>
        @if (orders.Data?.Any()??false)
                {
        <table class="table text-@SessionParent.ThemeInfo.GetCss col-xl-9">
            <thead>
                <tr>
                    <th>
                        <PBFrontend.UI.Formatting.Localize Value="Details" />
                    </th>
                    <th>
                        <PBFrontend.UI.Formatting.Localize Value="Origin" />&nbsp;&rArr;&nbsp;<PBFrontend.UI.Formatting.Localize Value="Target" />
                    </th>
                    <th>
                        <PBFrontend.UI.Formatting.Localize Value="Deadline" />
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in orders.Data)
                {
                    <tr>
                        <td>
                            <LogisticsOrderDetails Order="order" />
                        </td>
                        <td>
                            @(String.IsNullOrWhiteSpace(order.Origin) ? SessionParent.Localize("Whereever") : order.Origin)&nbsp;&rarr;&nbsp;@order.Target
                        </td>
                        <td>
                            <PBFrontend.UI.Formatting.Localize Value="until" /> @SessionParent.Localize(order.Deadline)
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        }
                else
                {
        <PBFrontend.UI.Formatting.Box.Presets.InfoBox>
            <Header>
                <span class="oi oi-info"></span> Info
            </Header>
            <ChildContent>
                <PBFrontend.UI.Formatting.Localize Value="No Orders found." />
            </ChildContent>
        </PBFrontend.UI.Formatting.Box.Presets.InfoBox>
        }
    </ChildContent>
</PBFrontend.UI.Formatting.Box.Presets.Shadow.ShadowPageBox>